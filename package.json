{
  "$schema": "https://json.schemastore.org/package",
  "name": "@skilbjo/logger",
  "version": "0.0.1",
  "main": "index.js",
  "type": "module",
  "typings": "index.d.ts",
  "private": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public",
    "provenance": true
  },
  "author": "skilbjo",
  "keywords": [
    "api",
    "sdk",
    "openapi"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skilbjo/logger.git"
  },
  "files": [
    "dist"
  ],
  "license": "ISC",
  "scripts": {
    "prepare": "husky",
    "exec": "node",
    "eslint": "eslint .",
    "depcheck": "depcheck",
    "lint": "npm run eslint",
    "lint:fix": "eslint --fix .",
    "test": "node --test",
    "build": "tsgo -p tsconfig.build.json",
    "postbuild": "node -e \"const f=require('fs'),{dirname,join,relative}=require('path'),p=JSON.parse(f.readFileSync('package.json','utf8'));delete p.files;p.imports=Object.fromEntries(Object.entries(p.imports??{}).map(([k,v])=>[k,Object.fromEntries(Object.entries(v).filter(([c])=>c!=='node').map(([c,s])=>{const x=s.replace('./dist/','./').replace('./src/','./');return[c,x.endsWith('.ts')?x.slice(0,-3)+'.d.ts':x]}))]));f.writeFileSync('dist/package.json',JSON.stringify(p,null,2));function fix(dir,root){for(const e of f.readdirSync(dir,{withFileTypes:true})){const fp=join(dir,e.name);if(e.isDirectory())fix(fp,root);else if(fp.endsWith('.js')||fp.endsWith('.d.ts')){const o=f.readFileSync(fp,'utf8'),u=o.replace(/from '#src\\/([^']+)'/g,(_,m)=>{const t=join(root,m);let r=relative(dirname(fp),t);if(!r.startsWith('.'))r='./'+r;return\\`from '\\${r}'\\`});if(o!==u)f.writeFileSync(fp,u)}}}fix('dist','dist')\"",
    "prepare-npm": "jq 'del(.publishConfig, .files) | . + { publishConfig: { registry: \"https://registry.npmjs.org/\", access: \"public\", provenance: true } }' package.json >package2.json && mv package2.json dist/package.json"
  },
  "dependencies": {
    "pino": "10.3.1",
    "winston": "3.19.0"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.2",
    "@commitlint/config-angular": "20.5.0",
    "@skilbjo/config-rc": "1.0.55",
    "@types/http-errors": "2.0.5",
    "depcheck": "1.4.7",
    "eslint": "10.2.1",
    "http-errors": "2.0.1",
    "husky": "9.1.7",
    "typescript": "npm:@typescript/native-preview@7.0.0-dev.20260426.1"
  },
  "imports": {
    "#src/*.js": {
      "node": "./src/*.ts",
      "import": "./dist/*.js",
      "types": "./src/*.ts"
    },
    "#test/*.js": "./test/*.ts"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    },
    "./*": {
      "types": "./*.d.ts",
      "import": "./*.js"
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-angular"
    ]
  },
  "engines": {
    "node": ">=24.14.1"
  }
}
